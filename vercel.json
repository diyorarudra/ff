{
  "framework": null,
  "buildCommand": "npm run build",
  "outputDirectory": ".",
  "cleanUrls": true,
  "redirects": [
    { "source": "/reports/:path*", "destination": "/404", "permanent": false }
  ],
  "rewrites": [
    { "source": "/games/game:id", "destination": "/games/game:id/index.html" },
    { "source": "/blog/:slug", "destination": "/blog/:slug/index.html" },
    { "source": "/play", "destination": "/play.html" }
  ]
}
