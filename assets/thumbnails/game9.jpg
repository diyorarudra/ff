<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 400 250" width="400" height="250">
        <defs>
            <linearGradient id="grad9" x1="0%" y1="0%" x2="100%" y2="100%">
                <stop offset="0%" style="stop-color:#33FFCC;stop-opacity:1" />
                <stop offset="100%" style="stop-color:#3366FF;stop-opacity:1" />
            </linearGradient>
            <pattern id="grid9" width="40" height="40" patternUnits="userSpaceOnUse">
                <path d="M 40 0 L 0 0 0 40" fill="none" stroke="rgba(255,255,255,0.1)" stroke-width="2"/>
            </pattern>
        </defs>
        <rect width="400" height="250" fill="url(#grad9)" />
