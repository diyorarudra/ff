{
  "name": "ffliveplay",
  "version": "1.0.0",
  "description": "ffliveplay HTML5 Gaming Platform",
  "main": "index.html",
  "scripts": {
    "start": "serve .",
    "dev": "serve .",
    "postbuild": "node scripts/hydrate-game-metadata.js && node scripts/verify-game-seo.js",
    "build": "node scripts/verify-game-seo.js",
    "audit:adsense": "node scripts/audit-adsense-readiness.js",
    "audit:adsense:release": "node scripts/audit-adsense-readiness.js --require-real-id"
  },
  "dependencies": {
    "canvas": "^3.2.3",
    "jsdom": "^29.1.1",
    "puppeteer": "^25.3.0",
    "pureimage": "^0.4.18",
    "serve": "^14.2.1"
  },
  "devDependencies": {
    "tailwindcss": "^3.4.19"
  }
}
